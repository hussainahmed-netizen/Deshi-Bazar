{
  "name": "Coupon",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "title": "Coupon Code"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "image_url": {
      "type": "string",
      "title": "Banner Image URL"
    },
    "bg_color": {
      "type": "string",
      "title": "Background Color"
    },
    "discount_type": {
      "type": "string",
      "title": "Discount Type",
      "enum": [
        "percentage",
        "fixed"
      ]
    },
    "amount": {
      "type": "number",
      "title": "Discount Amount"
    },
    "min_order": {
      "type": "number",
      "title": "Minimum Order (BDT)"
