    "max_uses": {
      "type": "number",
      "title": "Max Uses (0 = unlimited)"
    },
    "used_count": {
      "type": "number",
      "title": "Times Used"
    },
    "expiry_date": {
      "type": "string",
      "title": "Expiry Date"
