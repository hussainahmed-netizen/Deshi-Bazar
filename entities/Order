{
  "name": "Order",
  "type": "object",
  "properties": {
    "order_number": {
      "type": "string",
      "title": "Order Number"
    },
    "user_email": {
      "type": "string",
      "title": "User Email"
    },
    "items": {
      "type": "array",
      "title": "Order Items",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string"
          },
          "product_name": {
            "type": "string"
          },
          "product_image": {
            "type": "string"
          },
          "price": {
            "type": "number"
          },
          "quantity": {
            "type": "number"
          },
          "size": {
            "type": "string"
          },
          "color": {
            "type": "string"
          }
        }
      }
    },
    "subtotal": {
      "type": "number",
      "title": "Subtotal"
    },
    "shipping_cost": {
      "type": "number",
      "title": "Shipping Cost"
    },
    "total": {
      "type": "number",
      "title": "Total"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "pending",
        "confirmed",
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ]
    },
    "shipping_name": {
      "type": "string",
      "title": "Shipping Name"
    },
    "shipping_phone": {
      "type": "string",
      "title": "Shipping Phone"
    },
    "shipping_address": {
      "type": "string",
      "title": "Shipping Address"
    },
    "shipping_city": {
      "type": "string",
      "title": "Shipping City"
    },
    "payment_method": {
      "type": "string",
      "title": "Payment Method",
      "enum": [
        "cod",
        "bkash",
        "nagad",
        "card"
      ]
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": [
    "order_number",
    "user_email",
    "items",
    "total",
    "status",
    "shipping_name",
    "shipping_phone",
    "shipping_address"
  ]
}